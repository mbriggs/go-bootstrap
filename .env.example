# bin/setup generates .env with names derived from the module path; this
# file documents the shape.
PGUSER=yourproject
PGPASSWORD=yourproject
PGDATABASE=yourproject_dev
PGHOST=localhost
PGPORT=5432

# Error tracking lights up when set; 5xx responses and discarded jobs report.
# SENTRY_RELEASE tags events with a deploy version.
# SENTRY_DSN=https://...@o0.ingest.sentry.io/0
