{
  "permissions": {
    "allow": ["Bash(bin/check:*)"]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-edit.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/bin/agent-stop-check\"",
            "timeout": 300,
            "statusMessage": "bin/check"
          }
        ]
      }
    ]
  }
}
