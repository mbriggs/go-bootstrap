#!/usr/bin/env bash
#
# Regenerates all generated code. The directives in gen.go are the source
# of truth; this script exists so the workflow reads bin/<verb> like the
# rest of the toolchain. Run after bin/migrate up or after adding/removing a
# FooTx. Output is committed; bin/check fails if it drifts.

set -euo pipefail
cd "$(dirname "$0")/.."

# templ first so a single run leaves everything fresh; nothing downstream
# type-checks, so the order is convenience, not correctness.
templ generate

go generate .
