#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
CHECK=0

case "${1:-}" in
  "")
    ;;
  "--check")
    CHECK=1
    ;;
  *)
    echo "Unknown argument: $1" >&2
    exit 1
    ;;
esac

node --input-type=module - "$ROOT" "$CHECK" <<'JS'
import fs from "node:fs";
import path from "node:path";
import { execFileSync } from "node:child_process";

const root = process.argv[2];
const check = process.argv[3] === "1";
const notice =
  "<!-- Generated by bin/sync-agent-config. Edit ai/ or nested CLAUDE.md files, then re-run. -->\n\n";
const aiDir = path.join(root, "ai");
const commonDir = path.join(aiDir, "common");
const rulesDir = path.join(aiDir, "rules");
const claudeRulesDir = path.join(root, ".claude", "rules");

function rel(file) {
  return path.relative(root, file);
}

function read(file) {
  return fs.readFileSync(file, "utf8");
}

function write(file, content) {
  fs.mkdirSync(path.dirname(file), { recursive: true });
  fs.writeFileSync(file, content, "utf8");
}

function markdownFiles(dir) {
  if (!fs.existsSync(dir)) return [];
  return fs
    .readdirSync(dir)
    .filter((name) => name.endsWith(".md") && fs.statSync(path.join(dir, name)).isFile())
    .sort();
}

function normalizeBody(body) {
  return body.trim().replace(/\n{3,}/g, "\n\n");
}

function parseFrontmatter(source, file) {
  if (!source.startsWith("---\n")) return { data: {}, body: source };
  const end = source.indexOf("\n---\n", 4);
  if (end === -1) throw new Error(`${rel(file)} has unterminated frontmatter`);

  const raw = source.slice(4, end);
  const body = source.slice(end + 5);
  const data = {};
  let currentKey = null;

  for (const line of raw.split("\n")) {
    if (line.trim() === "") continue;
    const listMatch = line.match(/^\s*-\s*(.*)$/);
    if (listMatch && currentKey) {
      data[currentKey].push(unquote(listMatch[1].trim()));
      continue;
    }

    const keyMatch = line.match(/^([A-Za-z][A-Za-z0-9_-]*):\s*(.*)$/);
    if (!keyMatch) throw new Error(`${rel(file)} has unsupported frontmatter line: ${line}`);
    currentKey = keyMatch[1];
    const value = keyMatch[2].trim();
    data[currentKey] = value === "" ? [] : unquote(value);
  }

  return { data, body };
}

function unquote(value) {
  if (
    (value.startsWith('"') && value.endsWith('"')) ||
    (value.startsWith("'") && value.endsWith("'"))
  ) {
    return value.slice(1, -1);
  }
  return value;
}

function loadCommonSections() {
  return markdownFiles(commonDir)
    .map((name) => read(path.join(commonDir, name)).trim())
    .filter(Boolean);
}

function loadRules() {
  return markdownFiles(rulesDir).map((name) => {
    const file = path.join(rulesDir, name);
    const parsed = parseFrontmatter(read(file), file);
    const title = parsed.data.title || path.basename(name, ".md");
    const claudePaths = parsed.data.claudePaths || parsed.data.paths;
    if (!Array.isArray(claudePaths) || claudePaths.length === 0) {
      throw new Error(`${rel(file)} must define claudePaths as a non-empty list`);
    }
    if (!claudePaths.every((entry) => typeof entry === "string")) {
      throw new Error(`${rel(file)} claudePaths entries must be strings`);
    }

    return {
      body: normalizeBody(parsed.body),
      claudePaths,
      fileName: name,
      title,
    };
  });
}

function buildCodexRoot(commonSections, rules) {
  const sections = [...commonSections];
  if (rules.length > 0) {
    sections.push(rules.map((rule) => `## ${rule.title}\n\n${rule.body}`).join("\n\n"));
  }
  return `${notice}${sections.join("\n\n")}\n`;
}

function buildClaudeRoot(commonSections) {
  const footer = [
    "## Scoped Rules",
    "",
    "Scoped Claude rules are generated from `ai/rules/` into `.claude/rules/`.",
    "Codex reads those same rules inline from `AGENTS.md`.",
  ].join("\n");

  return `${notice}${commonSections.join("\n\n")}\n\n${footer}\n`;
}

function buildClaudeRule(rule) {
  const frontmatter = [
    "---",
    "paths:",
    ...rule.claudePaths.map((entry) => `  - ${JSON.stringify(entry)}`),
    "---",
    "",
  ].join("\n");

  return `${frontmatter}${notice}# ${rule.title}\n\n${rule.body}\n`;
}

function rewriteClaudeIncludes(content) {
  return content.replace(/^@(.+)$/gm, (_match, target) => {
    return `Also read \`${target.trim().replace(/CLAUDE\.md$/, "AGENTS.md")}\`.`;
  });
}

function ignoredDir(relative) {
  return [
    ".git",
    ".claude",
    "coverage",
    "dist",
    "node_modules",
  ].some((prefix) => relative === prefix || relative.startsWith(`${prefix}/`));
}

function collectLocalAgents(plan, dir = root) {
  for (const entry of fs.readdirSync(dir, { withFileTypes: true })) {
    const file = path.join(dir, entry.name);
    const relative = rel(file);
    if (entry.isDirectory()) {
      if (!ignoredDir(relative)) collectLocalAgents(plan, file);
      continue;
    }

    if (entry.name !== "CLAUDE.md" || file === path.join(root, "CLAUDE.md")) continue;
    const agentsPath = path.join(dir, "AGENTS.md");
    plan.set(agentsPath, `${notice}${rewriteClaudeIncludes(read(file)).trim()}\n`);
  }
}

function buildPlan() {
  const commonSections = loadCommonSections();
  const rules = loadRules();
  const plan = new Map();

  plan.set(path.join(root, "AGENTS.md"), buildCodexRoot(commonSections, rules));
  plan.set(path.join(root, "CLAUDE.md"), buildClaudeRoot(commonSections));
  for (const rule of rules) {
    plan.set(path.join(claudeRulesDir, rule.fileName), buildClaudeRule(rule));
  }
  collectLocalAgents(plan);

  return { plan, expectedRuleFiles: new Set(rules.map((rule) => rule.fileName)) };
}

function generated(file) {
  return fs.existsSync(file) && fs.statSync(file).isFile() && read(file).includes(notice.trim());
}

function staleFiles(plan, expectedRuleFiles) {
  const stale = [];
  if (fs.existsSync(claudeRulesDir)) {
    for (const name of markdownFiles(claudeRulesDir)) {
      const file = path.join(claudeRulesDir, name);
      if (!expectedRuleFiles.has(name) && generated(file)) stale.push(file);
    }
  }

  collectGeneratedAgentFiles(root, stale, plan);
  return stale;
}

function collectGeneratedAgentFiles(dir, stale, plan) {
  for (const entry of fs.readdirSync(dir, { withFileTypes: true })) {
    const file = path.join(dir, entry.name);
    const relative = rel(file);
    if (entry.isDirectory()) {
      if (!ignoredDir(relative)) collectGeneratedAgentFiles(file, stale, plan);
      continue;
    }
    if (entry.name === "AGENTS.md" && file !== path.join(root, "AGENTS.md") && !plan.has(file)) {
      if (generated(file)) stale.push(file);
    }
  }
}

function ensureWritable(file) {
  if (!fs.existsSync(file)) return;
  if (generated(file)) return;
  if (rel(file) === "CLAUDE.md") return;
  throw new Error(`Refusing to overwrite non-generated ${rel(file)}`);
}

function checkPlan(plan, expectedRuleFiles) {
  const drifted = [];
  for (const [file, desired] of plan) {
    const existing = fs.existsSync(file) ? read(file) : null;
    if (existing !== desired) drifted.push(rel(file));
  }
  for (const file of staleFiles(plan, expectedRuleFiles)) {
    drifted.push(`${rel(file)} (orphan)`);
  }

  if (drifted.length === 0) return false;
  console.error("bin/sync-agent-config --check: drift detected. Run bin/sync-agent-config:");
  for (const file of drifted) console.error(`  - ${file}`);
  return true;
}

const { plan, expectedRuleFiles } = buildPlan();
if (check) {
  const drifted = checkPlan(plan, expectedRuleFiles);
  try {
    execFileSync(path.join(root, "bin", "link-skills"), ["--check"], {
      cwd: root,
      stdio: "inherit",
    });
  } catch {
    process.exit(1);
  }
  process.exit(drifted ? 1 : 0);
}

for (const [file, content] of plan) {
  ensureWritable(file);
  write(file, content);
}

for (const file of staleFiles(plan, expectedRuleFiles)) {
  fs.rmSync(file, { force: true });
}

execFileSync(path.join(root, "bin", "link-skills"), ["--adopt"], {
  cwd: root,
  stdio: "inherit",
});
JS
