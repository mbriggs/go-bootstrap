#!/usr/bin/env bash
set -euo pipefail

# Per-worktree DB + port isolation. Invoked by `.config/wt.toml`'s pre-start
# pipeline, but works with manual `git worktree add` too.
#
# Allocates a port from the pool (bin/port-allocate), then clones the dev
# database ($PGDATABASE) and the test template (<project>_template) into
# <name>_<port> copies via CREATE DATABASE ... TEMPLATE (fast file-copy at
# the Postgres level). Writes worktree.env with PORT, PGDATABASE, and
# TEMPLATE_DB overrides; mise loads it (see .mise.toml `_.file`), so the
# overrides flow through to bin/* and the dev server without further wiring.

# Refuse to run in the main checkout — only worktrees get isolation.
WORKTREE_DIR="$(git rev-parse --show-toplevel)"
ROOT_DIR="$(git worktree list --porcelain | head -1 | sed 's/^worktree //')"
cd "$WORKTREE_DIR"

if [[ "$WORKTREE_DIR" == "$ROOT_DIR" ]]; then
  echo "bin/worktree-setup is for worktrees, not the main checkout." >&2
  exit 1
fi

# Trust the worktree's .mise.toml — otherwise mise refuses to load it on
# first entry and PORT / PGDATABASE never reach the shell. Non-fatal if
# mise isn't installed.
command -v mise >/dev/null && mise trust >/dev/null 2>&1 || true

# ---- Copy gitignored env files from main ---------------------------------

if [[ ! -f .env ]]; then
  if [[ -f "$ROOT_DIR/.env" ]]; then
    cp "$ROOT_DIR/.env" .env
    echo "==> copied .env from $ROOT_DIR"
  else
    echo ".env missing in both worktree and $ROOT_DIR. Run bin/setup in the main checkout first." >&2
    exit 1
  fi
fi

branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo worktree)"
port="$("$ROOT_DIR/bin/port-allocate" "$branch")"
echo "==> allocated port $port"

# ---- DB clone -------------------------------------------------------------

# Source the copied .env to recover the PG connection variables.
set -a
# shellcheck source=/dev/null
. ./.env
set +a

[[ -n "${PGDATABASE:-}" ]] || { echo "PGDATABASE missing in .env" >&2; exit 1; }

project=$(basename "$(GOWORK=off go list -m)" | tr '-' '_' | tr '[:upper:]' '[:lower:]')
SRC_DEV_DB="$PGDATABASE"
SRC_TEMPLATE_DB="${project}_template"
DEV_DB="${SRC_DEV_DB}_${port}"
TEMPLATE_DB="${SRC_TEMPLATE_DB}_${port}"

db_exists() {
  [[ -n "$(psql -XAtqc "SELECT 1 FROM pg_database WHERE datname = '${1//\'/\'\'}'" postgres)" ]]
}

clone_db() {
  local src="$1" dst="$2"
  if db_exists "$dst"; then
    echo "==> $dst already exists, skipping clone"
    return
  fi
  echo "==> creating $dst from template $src"
  if ! createdb -T "$src" "$dst" 2>/tmp/wt-createdb.err; then
    cat /tmp/wt-createdb.err >&2
    echo >&2
    echo "If the error mentions 'is being accessed by other users', stop the dev server / psql sessions against '$src' and re-run." >&2
    exit 1
  fi
}

if db_exists "$SRC_DEV_DB"; then
  clone_db "$SRC_DEV_DB" "$DEV_DB"
else
  echo "Dev database '$SRC_DEV_DB' does not exist in the main checkout. Run bin/recreate there first." >&2
  exit 1
fi

if db_exists "$SRC_TEMPLATE_DB"; then
  clone_db "$SRC_TEMPLATE_DB" "$TEMPLATE_DB"
else
  echo "==> $SRC_TEMPLATE_DB does not exist, skipping test template clone (bin/testdb will create ${TEMPLATE_DB})"
fi

# ---- Write env overrides --------------------------------------------------

cat > worktree.env <<EOF
# Generated by bin/worktree-setup. Loaded by mise via .mise.toml _.file.
# Overrides values inherited from the copied .env.
PORT=${port}
PGDATABASE=${DEV_DB}
TEMPLATE_DB=${TEMPLATE_DB}
EOF

echo ""
echo "worktree ready"
echo "  port:     $port"
echo "  url:      http://localhost:${port}"
echo "  dev:      $DEV_DB"
echo "  template: $TEMPLATE_DB"
