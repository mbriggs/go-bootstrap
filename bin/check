#!/usr/bin/env bash
#
# The full verification gate: format, shellcheck, build, vet, custom
# analyzers, stock linters, go.mod tidy drift, codegen drift, and the test
# suite. The test template is verified, not rebuilt (bin/testdb --check):
# missing builds once, stale fails — rebuilding after a migration change
# is a deliberate act (bin/testdb), and the agent stop hook runs this
# whole gate, so it stays fast.

set -euo pipefail
cd "$(dirname "$0")/.."

unformatted=$(gofumpt -l . 2>/dev/null | grep -v '^tmp/' || true)
if [ -n "$unformatted" ]; then
  echo "gofumpt needed on:"
  echo "$unformatted"
  exit 1
fi

shellcheck -x -s bash bin/*

go build ./...
go vet ./...
go run ./cmd/lint ./...

if command -v golangci-lint >/dev/null; then
  golangci-lint run ./...
else
  echo "warning: golangci-lint not installed, skipping stock linters" >&2
fi

# go.mod tidy drift — run tidy against a throwaway copy so the check stays
# read-only. The copied .mise.toml lands at a path mise has never trusted,
# which makes shim-resolved tools refuse to run; the copy is identical to
# the repo's already-trusted config, so trust it for this command.
tidydir="$(mktemp -d)"
trap 'rm -rf "$tidydir"' EXIT
rsync -a --exclude .git --exclude tmp . "$tidydir/repo/"
cp go.mod go.sum "$tidydir/"
(cd "$tidydir/repo" && MISE_TRUSTED_CONFIG_PATHS="$tidydir" go mod tidy)
diff -u "$tidydir/go.mod" "$tidydir/repo/go.mod"
diff -u "$tidydir/go.sum" "$tidydir/repo/go.sum"

# Stale = regeneration changed something the index doesn't have: untracked
# new output (??) or a worktree modification (second status column set).
bin/generate
drift=$(git status --porcelain -- '*.gen.go' '*_templ.go' | grep -E '^(\?\?|.[^ ])' || true)
if [ -n "$drift" ]; then
  echo "generated code is stale or untracked — commit bin/generate output:"
  echo "$drift"
  exit 1
fi

bin/testdb --check
go test -race ./...

echo "all checks passed"
