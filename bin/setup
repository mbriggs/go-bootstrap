#!/usr/bin/env bash
#
# One-time setup: installs the toolchain via mise and generates .env with
# names derived from the module path. Postgres comes from a native install
# or `docker compose up -d` — see README.md.

set -euo pipefail
cd "$(dirname "$0")/.."

if ! command -v mise >/dev/null; then
  echo "mise is required to manage the toolchain: https://mise.jdx.dev/getting-started.html" >&2
  exit 1
fi

if ! command -v go >/dev/null; then
  echo "go is required to bootstrap mise's go-backed tools: https://go.dev/doc/install" >&2
  exit 1
fi

mise trust --quiet 2>/dev/null || true
mise install

create_env_file() {
  if [ -f .env ]; then
    echo ".env already exists."
    return
  fi

  local project
  project=$(basename "$(go list -m)" | tr '-' '_' | tr '[:upper:]' '[:lower:]')

  cat > .env <<ENVEOF
PGUSER=$project
PGPASSWORD=$project
PGDATABASE=${project}_dev
PGHOST=localhost
PGPORT=5432

TERN_MIGRATIONS=migrations
ENVEOF

  echo "Created .env for $project."
}

create_env_file

echo "Setup complete. Next: create the Postgres role and run bin/recreate (see README.md)."
